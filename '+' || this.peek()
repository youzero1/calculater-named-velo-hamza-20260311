import React from 'react';
import styles from './Button.module.css';

export type ButtonVariant = 'default' | 'operator' | 'special' | 'equals';

interface ButtonProps {
  label: string;
  onClick: () => void;
  variant?: ButtonVariant;
  wide?: boolean;
  ariaLabel?: string;
}

const Button: React.FC<ButtonProps> = ({
  label,
  onClick,
  variant = 'default',
  wide = false,
  ariaLabel,
}) => {
  const classNames = [
    styles.button,
    variant !== 'default' ? styles[variant] : '',
    wide ? styles.wide : '',
  ]
    .filter(Boolean)
    .join(' ');

  return (
    <button
      className={classNames}
      onClick={onClick}
      aria-label={ariaLabel || label}
      type="button"
    >
      {label}
    </button>
  );
};

export default Button;
