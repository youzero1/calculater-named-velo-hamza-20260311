'-')) {
      const op = this.consume();
      const right = this.term();
      if (op === '+') {
        left = left + right;
      } else {
        left = left - right;
      }
    }
    return left;
  }

  private term(): number {
    let left = this.unary();
    while (this.pos < this.tokens.length && ('*/%'.includes(this.peek()))) {
      const op = this.consume();
      const right = this.unary();
      if (op === '*') {
        left = left * right;
      } else if (op === '/') {
        if (right === 0) {
          throw new Error('Division by zero');
        }
        left = left / right;
      } else {
        if (right === 0) {
          throw new Error('Division by zero');
        }
        left = left % right;
      }
    }
    return left;
  }

  private unary(): number {
    if (this.peek() === '-') {
      this.consume();
      return -this.unary();
    }
    if (this.peek() === '+') {
      this.consume();
      return this.unary();
    }
    return this.factor();
  }

  private factor(): number {
    const token = this.peek();

    if (token === '(') {
      this.consume(); // consume '('
      const result = this.expression();
      if (this.peek() !== ')') {
        throw new Error('Missing closing parenthesis');
      }
      this.consume(); // consume ')'
      return result;
    }

    // Must be a number
    const num = this.consume();
    const value = parseFloat(num);
    if (isNaN(value)) {
      throw new Error(`Invalid number: ${num}`);
    }
    return value;
  }

  private peek(): string {
    if (this.pos >= this.tokens.length) {
      throw new Error('Unexpected end of expression');
    }
    return this.tokens[this.pos];
  }

  private consume(): string {
    const token = this.peek();
    this.pos++;
    return token;
  }
}

export function evaluate(expression: string): number {
  const trimmed = expression.trim();
  if (!trimmed) {
    throw new Error('Empty expression');
  }

  // Security: only allow valid characters
  if (!/^[\d\s+\-*/.()%]+$/.test(trimmed)) {
    throw new Error('Invalid characters in expression');
  }

  const tokens = tokenize(trimmed);
  if (tokens.length === 0) {
    throw new Error('Empty expression');
  }

  const parser = new Parser(tokens);
  const result = parser.parse();

  if (!isFinite(result)) {
    throw new Error('Result is not finite');
  }

  return result;
}

export function formatResult(value: number): string {
  // Avoid floating point display issues
  if (Number.isInteger(value)) {
    return value.toString();
  }

  // Limit to 10 decimal places and strip trailing zeros
  const formatted = parseFloat(value.toFixed(10)).toString();

  // If the result is very long, use exponential notation
  if (formatted.length > 15) {
    return value.toExponential(6);
  }

  return formatted;
}
