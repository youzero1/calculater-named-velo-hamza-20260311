'c' || key === 'C') {
        handleAction('clear');
      } else if (key === '%') {
        handleAction('percent');
      } else if (key === 'Backspace') {
        if (display.length > 1) {
          setDisplay(display.slice(0, -1));
        } else {
          setDisplay('0');
        }
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [handleAction, display]);

  const handleHistoryClick = (record: CalculationRecord) => {
    setDisplay(record.result);
    setExpression(record.expression + ' =');
    setJustEvaluated(true);
    setHasError(false);
  };

  return (
    <div className={styles.calculator}>
      <Display expression={expression} result={display} error={hasError} />
      <div className={styles.grid}>
        {BUTTONS.map((btn) => (
          <Button
            key={btn.label}
            label={btn.label}
            variant={btn.variant}
            wide={btn.wide}
            onClick={() => handleAction(btn.action)}
          />
        ))}
      </div>
      <div className={styles.history}>
        <div className={styles.historyTitle}>History</div>
        {history.length === 0 ? (
          <div className={styles.noHistory}>No calculations yet</div>
        ) : (
          history.slice(0, 10).map((record) => (
            <div
              key={record.id}
              className={styles.historyItem}
              onClick={() => handleHistoryClick(record)}
              role="button"
              tabIndex={0}
              onKeyDown={(e) => {
                if (e.key === 'Enter') handleHistoryClick(record);
              }}
            >
              <span className={styles.historyExpression}>
                {record.expression}
              </span>
              <span className={styles.historyResult}>= {record.result}</span>
            </div>
          ))
        )}
      </div>
    </div>
  );
};

export default Calculator;
